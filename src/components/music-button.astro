---
const audioFiles = Object.keys(import.meta.glob('/public/audio/*.mp3')).map(
  (p) => p.replace('/public', '')
)
---

<button id="musicToggle" aria-label="Play ambient music" aria-pressed="false" data-tracks={JSON.stringify(audioFiles)}>
  <svg width="18px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path class="music-icon music-play" d="M8 5v14l11-7z" />
    <g class="music-icon music-pause" style="display:none">
      <rect x="6" y="4" width="4" height="16" />
      <rect x="14" y="4" width="4" height="16" />
    </g>
  </svg>
</button>

<audio id="ambientAudio" preload="none" transition:persist></audio>

<script>
  import "../scripts/music-player";
</script>

<style>
  #musicToggle {
    border: 0;
    background: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
  }

  .music-icon {
    fill: black;
  }

  :global(.dark) .music-icon {
    fill: white;
  }

</style>
