---
import AvatarImage from '@components/avatar-image.astro'
import ThemeButton from '@components/theme-button.astro'
import { navLinks, isActivePath } from '@utils/nav-links'

const currentPath = Astro.url.pathname
---

<section class="flex flex-col items-center justify-center">
  <AvatarImage />
</section>
<nav class="nav-links mt-10 mb-4 flex items-center justify-center gap-10" aria-label="Main">
  {navLinks.map((item) => (
    <a href={item.url} class:list={[{ 'text-primary': isActivePath(item.url, currentPath) }]} aria-current={isActivePath(item.url, currentPath) ? 'page' : undefined}>{item.title}</a>
  ))}
  <ThemeButton class="absolute right-0" />
</nav>
<hr class="separator" />