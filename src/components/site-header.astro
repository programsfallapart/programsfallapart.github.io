---
import AvatarImage from "@components/avatar-image.astro";
import ThemeButton from "@components/theme-button.astro";
import MusicButton from "@components/music-button.astro";
import { navLinks, isActivePath } from "@utils/nav-links";

interface Props {
  isHome?: boolean
}

const { isHome = false } = Astro.props
const currentPath = Astro.url.pathname;
---

<header>
  {isHome ? (
    <h1 class="sr-only">Programs Fall Apart</h1>
  ) : (
    <p class="sr-only">Programs Fall Apart</p>
  )}
  <section class="flex flex-col items-center justify-center">
    <AvatarImage />
  </section>
  <nav
    class="nav-links mt-10 mb-4 flex items-center justify-center gap-10"
    aria-label="Main"
  >
    {
      navLinks.map((item) => (
        <a
          href={item.url}
          class:list={[{ "text-primary": isActivePath(item.url, currentPath) }]}
          aria-current={isActivePath(item.url, currentPath) ? "page" : undefined}
        >
          {item.title}
        </a>
      ))
    }
    <span class="nav-divider" aria-hidden="true"></span>
    <ThemeButton />
    <MusicButton />
  </nav>
  <p class="now-playing" id="nowPlayingBar">
    <button class="track-btn" id="prevTrack" aria-label="Previous track">&lsaquo;</button>
    <span id="nowPlaying" aria-live="polite">&nbsp;</span>
    <button class="track-btn" id="nextTrack" aria-label="Next track">&rsaquo;</button>
  </p>
  <hr class="separator" />
</header>

<style>
  .nav-links {
    flex-wrap: wrap;

    a {
      font-family: "JetBrains Mono";
      font-size: 0.7rem;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: theme("colors.muted");

      &.text-primary {
        color: theme("colors.primary");
      }
    }

    @media screen and (max-width: 768px) {
      gap: 1.5rem !important;

      a {
        font-size: 0.6rem;
        letter-spacing: 2px;
      }
    }
  }

  .nav-divider {
    width: 1px;
    height: 14px;
    background: var(--color-border);
  }

  .now-playing {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: "JetBrains Mono", monospace;
    letter-spacing: -0.02em;
    font-size: 0.5rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
    user-select: all;
    visibility: hidden;
  }

  .track-btn {
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--color-muted);
    padding: 0 0.15rem;
    line-height: 1;
  }
</style>
