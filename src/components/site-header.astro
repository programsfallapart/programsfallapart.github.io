---
import AvatarImage from "@components/avatar-image.astro";
import ThemeButton from "@components/theme-button.astro";
import MusicButton from "@components/music-button.astro";
import { navLinks, isActivePath } from "@utils/nav-links";

const currentPath = Astro.url.pathname;
---

<section class="flex flex-col items-center justify-center">
  <AvatarImage />
</section>
<nav
  class="nav-links mt-10 mb-4 flex items-center justify-center gap-10"
  aria-label="Main"
>
  {
    navLinks.map((item) => (
      <a
        href={item.url}
        class:list={[{ "text-primary": isActivePath(item.url, currentPath) }]}
        aria-current={isActivePath(item.url, currentPath) ? "page" : undefined}
      >
        {item.title}
      </a>
    ))
  }
  <span class="nav-divider" aria-hidden="true"></span>
  <ThemeButton />
  <MusicButton />
</nav>
<p class="now-playing" id="nowPlayingBar">
  <span id="nowPlaying">&nbsp;</span>
</p>
<hr class="separator" />

<style>
  .nav-divider {
    width: 1px;
    height: 14px;
    background: var(--color-border);
  }

  .now-playing {
    text-align: center;
    font-family: "JetBrains Mono", monospace;
    letter-spacing: -0.02em;
    font-size: 0.5rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
    user-select: all;
    visibility: hidden;
  }
</style>
