---
interface Heading {
  depth: number
  slug: string
  text: string
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3)
---

{tocHeadings.length > 0 && (
  <details class="inline-toc">
    <summary>Table of contents</summary>
    <ul>
      {tocHeadings.map((h) => (
        <li>
          <a href={`#${h.slug}`} class={h.depth === 3 ? 'toc-h3' : ''}>
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </details>
)}

<style>
  .inline-toc {
    display: block;
    margin-bottom: 2rem;
    font-family: 'JetBrains Mono';
    font-size: 0.7rem;
  }

  .inline-toc summary {
    cursor: pointer;
    color: theme('colors.muted');
    list-style: none;
  }

  .inline-toc summary::before {
    content: '+ ';
  }

  .inline-toc[open] summary::before {
    content: '- ';
  }

  .inline-toc ul {
    list-style: none;
    padding: 0.5rem 0 0 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .inline-toc a {
    color: theme('colors.muted');
    text-decoration: none;
    line-height: 1.8;
  }

  .inline-toc a:hover {
    color: theme('colors.primary');
  }

  .inline-toc .toc-h3 {
    padding-left: 1rem;
  }
</style>
