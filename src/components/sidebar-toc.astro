---
interface Heading {
  depth: number
  slug: string
  text: string
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3)
const h2Headings = headings.filter((h) => h.depth === 2)
---

{h2Headings.length > 0 && (
  <div id="sidebar-toc" class="sidebar-toc" role="navigation" aria-label="Table of contents">
    <div id="sidebar-toc-lines" class="sidebar-toc-lines" role="group" aria-label="Reading progress">
      {h2Headings.map((h, i) => (
        <div class="sidebar-toc-line" role="presentation" aria-hidden="true" />
      ))}
    </div>
    <div id="sidebar-toc-panel" class="sidebar-toc-panel">
      <ul id="sidebar-toc-list">
        {tocHeadings.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class={h.depth === 3 ? 'toc-h3' : ''}
              data-slug={h.slug}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
)}


<style>
  .sidebar-toc {
    position: fixed;
    right: clamp(1rem, 3vw, 2rem);
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    contain: layout;
  }

  .sidebar-toc-lines {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    cursor: pointer;
  }

  .sidebar-toc-line {
    height: 2px;
    width: 20px;
    background-color: var(--color-border);
    border-radius: 1px;
    transition: width 0.25s ease, background-color 0.25s ease;
  }

  .sidebar-toc-line.active {
    width: 36px;
    background-color: theme('colors.primary');
  }

  .sidebar-toc-line.passed {
    background-color: theme('colors.muted');
  }

  .sidebar-toc-panel {
    display: none;
    max-width: 280px;
    max-height: 60vh;
    overflow-y: auto;
    scrollbar-width: none;
    background: light-dark(rgba(255, 255, 255, 0.95), rgba(30, 30, 30, 0.95));
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    padding: 0.75rem 1rem;
    box-shadow: 0 4px 16px light-dark(rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.3));
  }

  .sidebar-toc-panel::-webkit-scrollbar {
    display: none;
  }

  @media (any-hover: hover) {
    .sidebar-toc:hover .sidebar-toc-panel {
      display: block;
    }
    .sidebar-toc:hover .sidebar-toc-lines {
      display: none;
    }
  }

  .sidebar-toc-panel.open {
    display: block;
  }

  .sidebar-toc-panel ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .sidebar-toc-panel li {
    margin: 0;
  }

  .sidebar-toc-panel a {
    font-family: 'JetBrains Mono';
    color: theme('colors.muted');
    font-size: 0.6rem;
    text-decoration: none;
    line-height: 1.8;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sidebar-toc-panel a:hover,
  .sidebar-toc-panel a.active {
    color: theme('colors.primary');
  }

  .sidebar-toc-panel .toc-h3 {
    padding-left: 1rem;
  }

  @media screen and (max-width: 1200px) {
    .sidebar-toc {
      display: none;
    }
  }

</style>

<script>
  function initToc() {
    const sidebarToc = document.getElementById('sidebar-toc');
    if (!sidebarToc) return;

    const lines = sidebarToc.querySelectorAll<HTMLElement>('.sidebar-toc-line');
    const tocLinks = sidebarToc.querySelectorAll<HTMLAnchorElement>('#sidebar-toc-list a');

    const h2s = Array.from(document.querySelectorAll('article h2')).filter(
      (h) => !h.closest('[data-footnotes]')
    );

    const h2Elements: Element[] = [];
    lines.forEach((_, i) => {
      if (h2s[i]) h2Elements.push(h2s[i]);
    });

    const allHeadingElements: Element[] = [];
    tocLinks.forEach((link) => {
      const slug = link.dataset.slug;
      const heading = document.getElementById(slug || '');
      if (heading) allHeadingElements.push(heading);
    });

    let skipUpdate = false;

    function setActive(lineIdx: number, tocIdx: number) {
      lines.forEach((line, i) => {
        line.classList.remove('active', 'passed');
        if (i === lineIdx) line.classList.add('active');
        else if (i < lineIdx) line.classList.add('passed');
      });
      tocLinks.forEach((a, i) => {
        a.classList.toggle('active', i === tocIdx);
      });
    }

    function update() {
      if (skipUpdate) return;

      let activeLineIndex = -1;
      h2Elements.forEach((h, idx) => {
        if (h.getBoundingClientRect().top <= window.innerHeight * 0.5) activeLineIndex = idx;
      });

      let activeTocIndex = -1;
      allHeadingElements.forEach((h, idx) => {
        if (h.getBoundingClientRect().top <= window.innerHeight * 0.5) activeTocIndex = idx;
      });

      setActive(activeLineIndex, activeTocIndex);
    }

    tocLinks.forEach((link, tocIdx) => {
      const slug = link.dataset.slug;
      const heading = document.getElementById(slug || '');
      if (heading) {
        link.addEventListener('click', (e) => {
          e.preventDefault();

          let lineIdx = h2Elements.indexOf(heading);
          if (lineIdx === -1) {
            for (let i = tocIdx - 1; i >= 0; i--) {
              const prev = allHeadingElements[i];
              const prevLineIdx = h2Elements.indexOf(prev);
              if (prevLineIdx !== -1) { lineIdx = prevLineIdx; break; }
            }
          }

          skipUpdate = true;
          setActive(lineIdx, tocIdx);
          heading.scrollIntoView({ behavior: 'smooth' });

          const panel = document.getElementById('sidebar-toc-panel');
          if (panel) panel.classList.remove('open');

          setTimeout(() => { skipUpdate = false; }, 800);
        });
      }
    });

    let tocTicking = false;
    window.addEventListener('scroll', () => {
      if (tocTicking) return;
      tocTicking = true;
      requestAnimationFrame(() => {
        update();
        tocTicking = false;
      });
    }, { passive: true });
    update();

    const linesEl = document.getElementById('sidebar-toc-lines');
    const panel = document.getElementById('sidebar-toc-panel');
    if (linesEl && panel) {
      linesEl.addEventListener('click', (e) => {
        e.stopPropagation();
        panel.classList.toggle('open');
      });
      document.addEventListener('click', (e) => {
        if (!sidebarToc.contains(e.target as Node)) {
          panel.classList.remove('open');
        }
      });
    }
  }

  initToc()
</script>
