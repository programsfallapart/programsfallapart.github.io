---
import type { Page } from 'astro'

interface Props {
  page: Page
}

const { page } = Astro.props
---

<span class="mono" style="font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase;">
{page.url.prev ? <a href={page.url.prev}>Prev</a> : null}
{!page.url.prev && !page.url.next ? null : page.currentPage}
{page.url.next ? <a href={page.url.next}>Next</a> : null}
</span>
