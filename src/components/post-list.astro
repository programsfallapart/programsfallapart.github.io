---
import type { WritingEntry } from '@interfaces/models'
import { formatedYMD, isoDate } from '@utils/date-helper'
import { getEntryLink } from '@utils/entry-link'

interface Props {
  writings: WritingEntry[]
}

const { writings } = Astro.props
---

<div class="flex flex-col">
  {
    writings.map((w) => (
      <div class="list-row flex items-baseline gap-x-8" data-list-row>
        <time class="date-mono" datetime={isoDate(w.entry.data.date)}>{formatedYMD(w.entry.data.date)}</time>
        <a href={getEntryLink(w)} class="flex-1 truncate">
          {w.entry.data.title}
        </a>
      </div>
    ))
  }
</div>
