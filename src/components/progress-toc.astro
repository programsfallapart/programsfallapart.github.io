---
interface Heading {
  depth: number
  slug: string
  text: string
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3)
const h2Headings = headings.filter((h) => h.depth === 2)
---

{h2Headings.length > 0 && (
  <div id="progress-toc" class="progress-toc" role="navigation" aria-label="Table of contents">
    <div id="progress-lines" class="progress-lines" role="group" aria-label="Reading progress">
      {h2Headings.map((h, i) => (
        <div class="toc-line" role="presentation" aria-hidden="true" />
      ))}
    </div>
    <div id="toc-panel" class="toc-panel">
      <ul id="toc-list">
        {tocHeadings.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class={h.depth === 3 ? 'toc-h3' : ''}
              data-slug={h.slug}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
)}

<style>
  .progress-toc {
    position: fixed;
    left: 2rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    contain: layout;
  }

  .progress-lines {
    display: flex;
    flex-direction: column;
    gap: 8px;
    cursor: pointer;
  }

  .toc-line {
    height: 2px;
    width: 20px;
    background-color: #d1d5db;
    border-radius: 1px;
    transition: width 0.25s ease, background-color 0.25s ease;
  }

  :global(.dark) .toc-line {
    background-color: theme('colors.primary-gray');
  }

  .toc-line.active {
    width: 36px;
    background-color: theme('colors.primary');
  }

  .toc-line.passed {
    background-color: theme('colors.muted');
  }

  :global(.dark) .toc-line.passed {
    background-color: theme('colors.muted');
  }

  .toc-panel {
    display: none;
    max-width: 280px;
    max-height: 60vh;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border: 1px solid #e5e5e5;
    border-radius: 5px;
    padding: 0.75rem 1rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  :global(.dark) .toc-panel {
    background: rgba(30, 30, 30, 0.95);
    border-color: #333;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  .toc-panel::-webkit-scrollbar {
    display: none;
  }

  @media (any-hover: hover) {
    .progress-toc:hover .toc-panel {
      display: block;
    }
    .progress-toc:hover .progress-lines {
      display: none;
    }
  }

  .toc-panel.open {
    display: block;
  }

  .toc-panel ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .toc-panel li {
    margin: 0;
  }

  .toc-panel a {
    font-family: 'JetBrains Mono';
    color: theme('colors.muted');
    font-size: 0.6rem;
    text-decoration: none;
    line-height: 1.8;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .toc-panel a:hover {
    color: theme('colors.primary');
  }

  .toc-panel a.active {
    color: theme('colors.primary');
  }

  .toc-panel .toc-h3 {
    padding-left: 1rem;
  }

  @media screen and (max-width: 1400px) {
    .progress-toc {
      left: 0.5rem;
    }
  }
</style>

<script>
  import "../scripts/progress-toc";
</script>
