---
import { createRequire } from 'node:module'
const cjsRequire = createRequire(import.meta.url)
const { active } = cjsRequire('../../palettes.config.cjs')
const ld = active.logo.dark
const ll = active.logo.light
---

<div class="site-logo mt-4 mb-1 select-none flex justify-center" style={`--lt:${ll.text};--la:${ll.accent};--lb1:${ll.bars[0]};--lb2:${ll.bars[1]};--lb3:${ll.bars[2]};--lb4:${ll.bars[3]};--lp1:${ll.particles[0]};--lp2:${ll.particles[1]};--lp3:${ll.particles[2]};--lp4:${ll.particles[3]};--dt:${ld.text};--da:${ld.accent};--db1:${ld.bars[0]};--db2:${ld.bars[1]};--db3:${ld.bars[2]};--db4:${ld.bars[3]};--dp1:${ld.particles[0]};--dp2:${ld.particles[1]};--dp3:${ld.particles[2]};--dp4:${ld.particles[3]}`}>
  <!-- Champion · stacked wordmark, stripped. Entropy cue: the final "t" of
       "apart" sits a hair below the baseline — subliminal, not a performance. -->
  <svg width="300" height="104" viewBox="0 0 300 104" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Programs Fall Apart logo">
    <text x="6" y="44" class="logo-grotesque logo-ink" font-size="38" letter-spacing="-1.5">programs</text>
    <text x="6" y="92" class="logo-grotesque logo-dim" font-size="38" letter-spacing="-1.5">fall apar<tspan dy="3">t</tspan></text>
  </svg>
</div>
<figure class="epigraph" lang="fr">
  <blockquote>
    <p class="epigraph-text">
      &#8220;Non pas des v&#233;rit&#233;s acquises, mais l&#8217;id&#233;e d&#8217;une recherche libre&#8221;
    </p>
  </blockquote>
  <figcaption class="epigraph-author">&#8212; <cite>Maurice Merleau-Ponty</cite></figcaption>
</figure>

<style>
  .site-logo :global(svg) {
    max-width: 100%;
    height: auto;
    aspect-ratio: 300 / 104;
  }

  /* Candidate-logo helpers (grotesque wordmark, ink field, knockout ground) */
  .site-logo :global(.logo-grotesque) {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
  }
  .site-logo :global(.logo-field),
  .site-logo :global(.logo-field-text) { fill: var(--lt); }
  :global(.dark) .site-logo :global(.logo-field),
  :global(.dark) .site-logo :global(.logo-field-text) { fill: var(--dt); }
  .site-logo :global(.logo-knockout) { fill: #f8f9fa; }
  :global(.dark) .site-logo :global(.logo-knockout) { fill: #181c21; }
  .site-logo :global(.logo-grid) { stroke: var(--lt); }
  :global(.dark) .site-logo :global(.logo-grid) { stroke: var(--dt); }
  /* "programs" anchors the logo — near-black in light, near-white in dark,
     so the hierarchy survives the inversion instead of washing out. */
  .site-logo :global(.logo-ink) { fill: #181c21; }
  :global(.dark) .site-logo :global(.logo-ink) { fill: #e6edf3; }
  /* "fall apart" one clear step dimmer than "programs" */
  .site-logo :global(.logo-dim) { fill: #6b7280; }
  :global(.dark) .site-logo :global(.logo-dim) { fill: #8b949e; }

  .site-logo :global(.logo-text-primary) { fill: var(--lt); }
  .site-logo :global(.logo-text-accent) { fill: var(--la); }
  .site-logo :global(.logo-bar-1) { fill: var(--lb1); color: var(--lb1); }
  .site-logo :global(.logo-bar-2) { fill: var(--lb2); color: var(--lb2); }
  .site-logo :global(.logo-bar-3) { fill: var(--lb3); color: var(--lb3); }
  .site-logo :global(.logo-bar-4) { fill: var(--lb4); color: var(--lb4); }
  .site-logo :global(.logo-p1) { fill: var(--lp1); color: var(--lp1); }
  .site-logo :global(.logo-p2) { fill: var(--lp2); color: var(--lp2); }
  .site-logo :global(.logo-p3) { fill: var(--lp3); color: var(--lp3); }
  .site-logo :global(.logo-p4) { fill: var(--lp4); color: var(--lp4); }

  :global(.dark) .site-logo :global(.logo-text-primary) { fill: var(--dt); }
  :global(.dark) .site-logo :global(.logo-text-accent) { fill: var(--da); }
  :global(.dark) .site-logo :global(.logo-bar-1) { fill: var(--db1); color: var(--db1); }
  :global(.dark) .site-logo :global(.logo-bar-2) { fill: var(--db2); color: var(--db2); }
  :global(.dark) .site-logo :global(.logo-bar-3) { fill: var(--db3); color: var(--db3); }
  :global(.dark) .site-logo :global(.logo-bar-4) { fill: var(--db4); color: var(--db4); }
  :global(.dark) .site-logo :global(.logo-p1) { fill: var(--dp1); color: var(--dp1); }
  :global(.dark) .site-logo :global(.logo-p2) { fill: var(--dp2); color: var(--dp2); }
  :global(.dark) .site-logo :global(.logo-p3) { fill: var(--dp3); color: var(--dp3); }
  :global(.dark) .site-logo :global(.logo-p4) { fill: var(--dp4); color: var(--dp4); }

  .epigraph {
    margin: 0.25rem auto 0;
    width: auto;
    text-align: center;
    white-space: nowrap;
  }

  .epigraph blockquote {
    margin: 0;
    padding: 0;
  }

  .epigraph-text {
    font-family: 'EB Garamond';
    font-style: italic;
    font-size: 0.8rem;
    line-height: 1.8;
    color: theme('colors.muted');
  }

  .epigraph-author {
    font-family: 'JetBrains Mono';
    font-size: 0.5rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-align: right;
    margin-top: 0.5rem;
    color: theme('colors.muted');
  }

  @media screen and (max-width: 768px) {
    .epigraph {
      width: 90%;
    }
  }
</style>