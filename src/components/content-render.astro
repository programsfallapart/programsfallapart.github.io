---
import type { PostModel, EssayModel } from '@interfaces/models'
import InlineToc from '@components/inline-toc.astro'
import { getFormatDate, isoDate } from '@utils/date-helper'
import { render } from 'astro:content'

interface Heading {
  depth: number
  slug: string
  text: string
}

interface Props {
  post: PostModel | EssayModel
  from?: string
  headings?: Heading[]
}

const { post, from, headings = [] } = Astro.props
const { Content } = await render(post)
---

<article>
  <h1 >{post.data.title}</h1>
  {
    (from === 'post' || from === 'essay') ? (
        <div class="flex items-baseline my-3">
          <div class="mono inline-flex items-center gap-2 flex-1 text-left" style="font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;">
            <span class="text-muted">{from}</span>
            {from === 'post' && (
              <>
                <span class="text-muted">&middot;</span>
                <time class="date-mono" datetime={isoDate(post.data.date)}>{getFormatDate(post.data.date)}</time>
              </>
            )}
          </div>
          <div class="mono inline-flex items-center gap-2" style="font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;">
            {post.data.tags.flatMap((tag, index, array) => [
              <a href={`/writings/?tag=${tag}`} class="text-accent">{tag}</a>,
              index < array.length - 1 ? <span class="text-muted">|</span> : null
            ])}
          </div>
        </div>
        <div class="metadata-divider" />
    ) : (
        ''
    )
  }
  <!-- <InlineToc headings={headings} /> -->
  <Content />
</article>

<script>
  // Give section headings a hover anchor for deep-linking (reader utility).
  function addHeadingAnchors() {
    const headings = document.querySelectorAll<HTMLElement>('article :is(h2, h3)[id]')
    headings.forEach((h) => {
      if (h.querySelector('.heading-anchor')) return
      const link = document.createElement('a')
      link.className = 'heading-anchor'
      link.href = `#${h.id}`
      link.setAttribute('aria-label', 'Link to this section')
      link.textContent = '#'
      h.appendChild(link)
    })
  }
  addHeadingAnchors()
</script>

<style>
  .metadata-divider {
    border-bottom: 0.5px solid var(--color-muted);
    margin-bottom: 1.5rem;
  }

  /* Hover anchors on section headings — invisible until you want them */
  article :global(:is(h2, h3)) {
    position: relative;
  }
  article :global(.heading-anchor) {
    margin-left: 0.4rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-muted);
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.15s ease, color 0.15s ease;
  }
  article :global(:is(h2, h3):hover) .heading-anchor,
  article :global(.heading-anchor:focus-visible) {
    opacity: 0.5;
  }
  article :global(.heading-anchor:hover) {
    opacity: 1;
    color: var(--color-primary);
  }
</style>
