---
import type { PostModel, EssayModel } from '@interfaces/models'
import GiscusComments from '@components/giscus-comments.astro'
import { getFormatDate, isoDate } from '@utils/date-helper'
import { render } from 'astro:content'
interface Props {
  post: PostModel | EssayModel
  from?: string
}

const { post, from } = Astro.props
const { Content } = await render(post)
---

<article>
  <h1 class:list={['mt-8', { 'text-center': from === 'post' || from === 'essay' }]}>{post.data.title}</h1>
  {
    (from === 'post' || from === 'essay') ? (
        <div class="flex items-baseline my-3">
          <div class="mono inline-flex items-center gap-2 flex-1 text-left" style="font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;">
            <span class="text-muted">{from}</span>
            {from === 'post' && 'date' in post.data && (
              <>
                <span class="text-muted">&middot;</span>
                <time class="date-mono" datetime={isoDate(post.data.date)}>{getFormatDate(post.data.date)}</time>
              </>
            )}
          </div>
          <div class="mono inline-flex items-center gap-2" style="font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;">
            {post.data.tags.flatMap((tag, index, array) => [
              <a href={`/writings/?tag=${tag}`} class="text-accent">{tag}</a>,
              index < array.length - 1 ? <span class="text-muted">&middot;</span> : null
            ])}
          </div>
        </div>
        <div style="margin-bottom: 1.5rem;" />
    ) : (
        ''
    )
  }
  <Content />
  <GiscusComments />
</article>
