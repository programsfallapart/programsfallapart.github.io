---
import type { PostModel } from '@interfaces/post-model'
import { getFormatDate } from '@utils/date-helper'
import { render } from 'astro:content'
import fs from 'node:fs'

interface Props {
  post: PostModel
  from?: string
}

const { post, from } = Astro.props
const { Content } = await render(post)

const giscusDarkCss = fs.readFileSync('public/giscus-dark.css', 'utf-8').replace(/\/\*!.*?\*\/\s*/s, '')
const giscusLightCss = fs.readFileSync('public/giscus-light.css', 'utf-8').replace(/\/\*!.*?\*\/\s*/s, '')
---

<article>
  <h1 class:list={['mt-8', { 'text-center': from && from === 'post' }]}>{post.data.title}</h1>
  {
    from === 'post' ? (
        <div class="flex items-baseline my-3">
          <div class="mono inline-flex items-center gap-2 flex-1 text-left" style="font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;">
            <span class="text-muted">post</span>
            <span class="text-muted">&middot;</span>
            <span class="date-mono">{getFormatDate(post.data.date)}</span>
          </div>
          <div class="mono inline-flex items-center gap-2" style="font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;">
            {post.data.tags.flatMap((tag, index, array) => [
              <a href={`/tags/${tag}`} class="text-accent">{tag}</a>,
              index < array.length - 1 ? <span class="text-muted">&middot;</span> : null
            ])}
          </div>
        </div>
        <div style="margin-bottom: 1.5rem;" />
    ) : (
        ''
    )
  }
  <Content />

  <section
    class="giscus mx-auto mt-10 w-full"
    data-dark-css={giscusDarkCss}
    data-light-css={giscusLightCss}
  ></section>
  <script>
    function getGiscusTheme() {
      const section = document.querySelector('.giscus')!
      const isDark = document.documentElement.classList.contains('dark')
      const css = isDark ? section.getAttribute('data-dark-css')! : section.getAttribute('data-light-css')!
      return `data:text/css;base64,${btoa(css)}`
    }

    function setGiscusTheme(theme: string) {
      const iframe = document.querySelector<HTMLIFrameElement>('iframe.giscus-frame')
      iframe?.contentWindow?.postMessage(
        { giscus: { setConfig: { theme } } },
        'https://giscus.app'
      )
    }

    function loadGiscus() {
      const existing = document.querySelector('script[src="https://giscus.app/client.js"]')
      if (existing) existing.remove()

      const script = document.createElement('script')
      script.src = 'https://giscus.app/client.js'
      script.setAttribute('data-repo', 'programsfallapart/programsfallapart.github.io')
      script.setAttribute('data-repo-id', 'R_kgDOLtiadA')
      script.setAttribute('data-category', 'General')
      script.setAttribute('data-category-id', 'DIC_kwDOLtiadM4Ceq7K')
      script.setAttribute('data-mapping', 'url')
      script.setAttribute('data-strict', '1')
      script.setAttribute('data-reactions-enabled', '1')
      script.setAttribute('data-emit-metadata', '0')
      script.setAttribute('data-input-position', 'top')
      script.setAttribute('data-theme', getGiscusTheme())
      script.setAttribute('data-lang', 'en')
      script.setAttribute('data-loading', 'lazy')
      script.setAttribute('crossorigin', 'anonymous')
      script.async = true
      document.querySelector('.giscus')?.appendChild(script)
    }

    // Watch for theme toggles
    const themeObserver = new MutationObserver(() => {
      setGiscusTheme(getGiscusTheme())
    })
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] })

    loadGiscus()
  </script>

  <script>
    const article = document.querySelector('article')
    if (article) {
      const footnotesSection = article.querySelector('[data-footnotes]') as HTMLElement
      if (footnotesSection) {

      const wideQuery = window.matchMedia('(min-width: 1100px)')
      const footnoteItems = footnotesSection.querySelectorAll('li')
      const sidenotes: HTMLElement[] = []

      function highlight(el: HTMLElement, scroll = false) {
        function apply() {
          el.classList.remove('highlight')
          void el.offsetWidth
          el.classList.add('highlight')
          setTimeout(() => el.classList.remove('highlight'), 1500)
        }
        if (scroll) {
          el.scrollIntoView({ behavior: 'smooth', block: 'center' })
          setTimeout(apply, 400)
        } else {
          apply()
        }
      }

      // Build sidenotes from footnotes
      footnoteItems.forEach((li) => {
        const refLink = article.querySelector(`a[href="#${li.id}"]`) as HTMLElement
        if (!refLink) return

        const content = li.cloneNode(true) as HTMLElement
        content.querySelectorAll('[data-footnote-backref]').forEach(el => el.remove())
        const inner = content.querySelector('p')
          ? content.querySelector('p')!.innerHTML.trim()
          : content.innerHTML.trim()

        const sidenote = document.createElement('div')
        sidenote.className = 'sidenote'
        sidenote.innerHTML = `<span class="sidenote-number">${refLink.textContent}.</span> ${inner} <a class="sidenote-backref" href="#${refLink.id}" title="Back to text">↩</a>`

        let insertAfter: HTMLElement | null = refLink.parentElement
        while (insertAfter && insertAfter.parentElement !== article) {
          insertAfter = insertAfter.parentElement
        }
        if (insertAfter) insertAfter.after(sidenote)
        else article.appendChild(sidenote)

        sidenotes.push(sidenote)
      })

      // Position sidenotes in the margin on wide screens
      if (wideQuery.matches && sidenotes.length > 0) {
        const articleRect = article.getBoundingClientRect()
        let lastBottom = 0
        footnoteItems.forEach((li, i) => {
          if (i >= sidenotes.length) return
          const refLink = article.querySelector(`a[href="#${li.id}"]`)
          if (!refLink) return
          const refTop = refLink.getBoundingClientRect().top - articleRect.top
          const top = Math.max(refTop, lastBottom)
          sidenotes[i].style.top = `${top}px`
          lastBottom = top + sidenotes[i].offsetHeight + 12
        })
      }

      // Wire up click handlers
      footnoteItems.forEach((li, i) => {
        if (i >= sidenotes.length) return
        const refLink = article.querySelector(`a[href="#${li.id}"]`) as HTMLElement
        if (!refLink) return

        // Inject number span into bottom footnote <li>
        const fnNum = document.createElement('span')
        fnNum.className = 'sidenote-number'
        fnNum.textContent = `${refLink.textContent}.`
        li.prepend(fnNum, ' ')

        // Click ref in main text → highlight number in sidenote or bottom footnote
        refLink.addEventListener('click', (e) => {
          e.preventDefault()
          const wide = wideQuery.matches
          const target = wide
            ? sidenotes[i].querySelector('.sidenote-number') as HTMLElement
            : fnNum
          highlight(target, !wide)
        })

        // Click ↩ in sidenote → highlight ref in main text
        const sideBackref = sidenotes[i].querySelector('.sidenote-backref') as HTMLAnchorElement
        sideBackref?.addEventListener('click', (e) => {
          e.preventDefault()
          highlight(refLink, true)
        })
      })

      // Click ↩ in bottom footnotes → highlight ref in main text
      footnotesSection.querySelectorAll<HTMLAnchorElement>('[data-footnote-backref]').forEach((backref) => {
        backref.addEventListener('click', (e) => {
          e.preventDefault()
          const target = document.getElementById(backref.getAttribute('href')!.slice(1)) as HTMLElement
          if (target) highlight(target, true)
        })
      })

      footnotesSection.classList.add('sidenotes-active')
      }
    }
  </script>

</article>