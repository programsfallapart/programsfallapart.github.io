---
import BaseLayout from "@layouts/base-layout.astro";
import { getAllPosts, getAllEssays } from "@utils/all-writings";
import { getEntryLink } from "@utils/entry-link";
import { formatedYMD, isoDate } from "@utils/date-helper";
import type { WritingEntry } from "@interfaces/models";

const latestEssays: WritingEntry[] = (await getAllEssays())
  .slice(0, 5)
  .map((entry) => ({ kind: "essay", entry }));
const latestPosts: WritingEntry[] = (await getAllPosts())
  .slice(0, 5)
  .map((entry) => ({ kind: "post", entry }));

const title = "Programs Fall Apart";
const description = "Software examined slowly. Writings on programming, architecture, and the connections between disciplines that specialization taught us to ignore.";
---

<BaseLayout title={title} description={description}>
  <!-- Latest Essays -->
  <section class="mb-20">
    <h2 class="section-heading mb-8">
      <a href="/writings/?category=essays" class="heading-link">Latest Essays</a>
    </h2>
    <div class="flex flex-col">
      {
        latestEssays.map((w) => (
          <div class="list-row flex items-baseline gap-x-8" data-list-row>
            <a class="flex-1 truncate" href={getEntryLink(w)}>
              {w.entry.data.title}
            </a>
            <time
              class="date-mono date-small"
              datetime={isoDate(w.entry.data.date)}
            >
              {formatedYMD(w.entry.data.date)}
            </time>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="mt-24">
    <h2 class="section-heading mb-8">
      <a href="/writings/?category=posts" class="heading-link">Latest Posts</a>
    </h2>
    <div class="flex flex-col">
      {
        latestPosts.map((w) => (
          <div class="list-row flex items-baseline gap-x-8" data-list-row>
            <a class="flex-1 truncate" href={getEntryLink(w)}>
              {w.entry.data.title}
            </a>
            <time
              class="date-mono date-small"
              datetime={isoDate(w.entry.data.date)}
            >
              {formatedYMD(w.entry.data.date)}
            </time>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .heading-link {
    text-decoration: none;
    color: inherit;
  }

  .heading-link:hover {
    color: theme("colors.primary");
  }

  .date-small {
    font-size: 0.55rem;
  }
</style>
