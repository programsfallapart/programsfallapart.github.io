---
import SiteHeader from "@components/site-header.astro";
import BaseLayout from "@layouts/base-layout.astro";
import { getAllPosts } from "@utils/all-posts";
import { getAllEssays } from "@utils/all-essays";
import { formatedYMD, isoDate } from "@utils/date-helper";
import { getPostLink } from "@utils/post-link";

const latestPosts = (await getAllPosts()).slice(0, 5);
const latestEssays = (await getAllEssays()).slice(0, 5);

const title = "Programs Fall Apart";
const description = "Software examined slowly. Writings on programming, architecture, and the connections between disciplines that specialization taught us to ignore.";
---

<BaseLayout title={title} description={description}>
  <SiteHeader isHome />
  <main id="main-content" tabindex="-1">
    <!-- Latest Essays -->
    <section class="mb-20">
      <h2 class="section-heading text-center mb-8">
        <a href="/writings/?category=essays" class="heading-link">Latest Essays</a>
      </h2>
      <div class="flex flex-col">
        {
          latestEssays.map((essay) => (
            <div class="post-row flex items-baseline gap-x-8" data-post-row>
              <a
                class="flex-1 truncate"
                href={`/essays/${essay.data.abbrlink}`}
              >
                {essay.data.title}
              </a>
              <span class="date-mono date-small">-</span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Latest Posts -->
    <section class="mt-24">
      <h2 class="section-heading text-center mb-8">
        <a href="/writings/?category=posts" class="heading-link">Latest Posts</a>
      </h2>
      <div class="flex flex-col">
        {
          latestPosts.map((post) => (
            <div class="post-row flex items-baseline gap-x-8" data-post-row>
              <a class="flex-1 truncate" href={getPostLink(post)}>
                {post.data.title}
              </a>
              <time
                class="date-mono date-small"
                datetime={isoDate(post.data.date)}
              >
                {formatedYMD(post.data.date)}
              </time>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .heading-link {
    text-decoration: none;
    color: inherit;
  }

  .heading-link:hover {
    color: theme("colors.primary");
  }

  .date-small {
    font-size: 0.55rem;
  }
</style>
