---
import AvatarImage from "@components/avatar-image.astro";
import ThemeButton from "@components/theme-button.astro";
import BaseLayout from "@layouts/base-layout.astro";
import { getAllPosts } from "@utils/all-posts";
import { getAllEssays } from "@utils/all-essays";
import { formatedYMD, isoDate } from "@utils/date-helper";
import { navLinks, isActivePath } from "@utils/nav-links";
import { getPostLink } from "@utils/post-link";

const latestPosts = (await getAllPosts()).slice(0, 5);
const latestEssays = (await getAllEssays()).slice(0, 5);

const title = "Programs Fall Apart";
const description = "Home - Programs Fall Apart";
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <section class="flex flex-col items-center justify-center">
      <AvatarImage />
    </section>
    <nav class="nav-links my-10 flex items-center justify-center gap-10" aria-label="Main">
      {navLinks.map((item) => (
        <a href={item.url} class:list={[{ 'text-primary': isActivePath(item.url, Astro.url.pathname) }]} aria-current={isActivePath(item.url, Astro.url.pathname) ? 'page' : undefined}>{item.title}</a>
      ))}
      <ThemeButton class="absolute right-0" />
    </nav>
    <hr class="separator" />

    <!-- Latest Essays -->
    <section class="my-16">
      <h2 class="section-heading text-center mb-8">
        <a href="/writings" class="heading-link">Latest Essays</a>
      </h2>
      <div class="flex flex-col">
        {
          latestEssays.map((essay) => (
            <div class="post-row flex items-baseline gap-x-8">
              <a class="flex-1 truncate" href={`/essays/${essay.data.abbrlink}`}>
                {essay.data.title}
              </a>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Latest Posts -->
    <section class="my-20">
      <h2 class="section-heading text-center mb-8">
        <a href="/writings" class="heading-link">Latest Posts</a>
      </h2>
      <div class="flex flex-col">
        {
          latestPosts.map((post) => (
            <div class="post-row flex items-baseline gap-x-8">
              <a class="flex-1 truncate" href={getPostLink(post)}>
                {post.data.title}
              </a>
              <time class="date-mono date-small" datetime={isoDate(post.data.date)}>{formatedYMD(post.data.date)}</time>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .heading-link {
    text-decoration: none;
    color: inherit;
  }

  .heading-link:hover {
    color: theme("colors.primary");
  }

  .date-small {
    font-size: 0.55rem;
  }
</style>
