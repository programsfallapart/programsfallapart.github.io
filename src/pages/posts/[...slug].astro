---
import ContentLayout from '@layouts/content-layout.astro'
import type { PostModel } from '@interfaces/post-model'
import { getAllPosts } from '@utils/all-posts'

interface Props {
  post: PostModel
}

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts.map((post) => ({
    params: { slug: post.data.abbrlink },
    props: { post },
  }))
}

const { post } = Astro.props
---

<ContentLayout entry={post} from="post" />
