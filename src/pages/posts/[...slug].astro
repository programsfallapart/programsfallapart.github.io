---
import ContentRender from '@components/content-render.astro'
import ProgressToc from '@components/progress-toc.astro'
import AvatarImage from '@components/avatar-image.astro'
import ThemeButton from "../../components/theme-button.astro";
import type { PostModel } from '@interfaces/post-model'
import BaseLayout from '@layouts/base-layout.astro'
import { getAllPosts } from '@utils/all-posts'
import { navLinks, isActivePath } from '@utils/nav-links'
import { render } from 'astro:content'

interface Props {
  post: PostModel
  prev: PostModel | undefined
  next: PostModel | undefined
}

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts.map((post, index) => ({
    params: { slug: post.data.abbrlink },
    props: { post, prev: posts[index - 1], next: posts[index + 1] },
  }))
}

const { post, prev, next } = Astro.props
const { headings: rawHeadings } = await render(post)
const headings = rawHeadings.filter((h) => h.slug !== 'footnote-label')
---

<BaseLayout title={post.data.title} description={post.data.description ?? ''}>
  <body>
  <main class="tufte">
    <section class="flex flex-col items-center justify-center">
      <AvatarImage />
    </section>
    <section class="nav-links my-10 flex items-center justify-center gap-10">
      {navLinks.map((item) => (<a href={item.url} class:list={[{ 'text-primary': isActivePath(item.url, Astro.url.pathname) }]}>{item.title}</a>))}
      <ThemeButton class="absolute right-0" />
    </section>
    <hr class="separator" />
    <section class="my-10">
      <ProgressToc headings={headings} />
      <ContentRender post={post} from="post" />
    </section>

      <hr class="separator" style="margin-top: 3rem;" />
      <div class="post-nav flex flex-wrap justify-between gap-x-12 py-2">
        {
          prev ? (
            <a
              class="post-nav-link flex-1 truncate text-left"
              href={'/posts/' + prev.data.abbrlink}
            >
              <span class="post-nav-label">&larr; Previous</span>
              <span class="post-nav-title">{prev.data.title}</span>
            </a>
          ) : (
            <span class="flex-1" />
          )
        }
        {
          next ? (
            <a
              class="post-nav-link flex-1 truncate text-right"
              href={'/posts/' + next.data.abbrlink}
            >
              <span class="post-nav-label">Next &rarr;</span>
              <span class="post-nav-title">{next.data.title}</span>
            </a>
          ) : (
            <span class="flex-1" />
          )
        }
      </div>
    </main>
  </body>
</BaseLayout>


