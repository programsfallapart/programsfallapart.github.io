---
import BaseLayout from "@layouts/base-layout.astro";
import { getAllPosts } from "@utils/all-posts";
import SiteHeader from "@components/site-header.astro";

const allPosts = await getAllPosts();

const uniqueTags = [
  ...new Set(allPosts.map((post) => post.data.tags).flat()),
].filter((tag) => tag) as string[];
const tagContent = uniqueTags.map((tag) => {
  const tagPost = allPosts.filter(
    (post) => post.data.tags && post.data.tags.includes(tag)
  );

  return {
    tag,
    count: tagPost.length,
  };
});

const title = "Tags";
const description = "Tags - Programs Fall Apart";
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <SiteHeader />
    <section class="flex flex-wrap gap-6 pt-1">
      {
        tagContent.map((item) => (
          <div class="flex justify-between">
            <a
              class="text-secondary mono"
              href={"/tags/" + item.tag}
              style="font-size: 0.85rem; letter-spacing: 1px;"
            >{`${item.tag?.slice(0, 1).toUpperCase()}${item.tag?.slice(1)}`}</a>
            <sup class="mono ml-2 mt-1 flex h-[14px] w-[14px] items-center justify-center rounded-full border text-[10px]">
              {item.count}
            </sup>
          </div>
        ))
      }
    </section>
  </main>
</BaseLayout>

<style>
  .text-secondary {
    color: theme('colors.muted');
  }
</style>
