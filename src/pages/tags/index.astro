---
import BaseLayout from "@layouts/base-layout.astro";
import { getAllPosts } from "@utils/all-posts";
import AvatarImage from "../../components/avatar-image.astro";
import ThemeButton from "../../components/theme-button.astro";
import { navLinks, isActivePath } from "@utils/nav-links";

const allPosts = await getAllPosts();

const uniqueTags = [
  ...new Set(allPosts.map((post) => post.data.tags).flat()),
].filter((tag) => tag) as string[];
const tagContent = uniqueTags.map((tag) => {
  const tagPost = allPosts.filter(
    (post) => post.data.tags && post.data.tags.includes(tag)
  );

  return {
    tag,
    count: tagPost.length,
  };
});

const title = "Tags";
const description = "Tags - Programs Fall Apart";
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <section class="flex flex-col items-center justify-center">
      <AvatarImage />
    </section>
    <nav class="nav-links my-10 flex items-center justify-center gap-10" aria-label="Main">
      {navLinks.map((item) => (<a href={item.url} class:list={[{ 'text-primary': isActivePath(item.url, Astro.url.pathname) }]} aria-current={isActivePath(item.url, Astro.url.pathname) ? 'page' : undefined}>{item.title}</a>))}
      <ThemeButton class="absolute right-0" />
    </nav>
    <hr class="separator" />
    <section class="flex flex-wrap gap-6 pt-1">
      {
        tagContent.map((item) => (
          <div class="flex justify-between">
            <a
              class="text-secondary mono"
              href={"/tags/" + item.tag}
              style="font-size: 0.85rem; letter-spacing: 1px;"
            >{`${item.tag?.slice(0, 1).toUpperCase()}${item.tag?.slice(1)}`}</a>
            <sup class="mono ml-2 mt-1 flex h-[14px] w-[14px] items-center justify-center rounded-full border text-[10px]">
              {item.count}
            </sup>
          </div>
        ))
      }
    </section>
  </main>
</BaseLayout>

<style>
  .text-secondary {
    color: theme('colors.muted');
  }
</style>
