---
import BaseLayout from "@layouts/base-layout.astro";
import { getAllWritings } from "@utils/all-writings";
import { getEntryLink } from "@utils/entry-link";
import { formatedYMD, isoDate } from "@utils/date-helper";
import { computeTagCounts } from "@utils/tag-counts";

const allWritings = await getAllWritings();

const allTags = [
  ...new Set(allWritings.flatMap((w) => w.entry.data.tags).filter(Boolean)),
] as string[];

const categories = ["posts", "essays"];

const tagCountsByCategory = computeTagCounts(
  allTags,
  allWritings.map((w) => ({
    tags: w.entry.data.tags || [],
    category: `${w.kind}s`,
  })),
  categories,
);

const title = "Writings";
const description = "Writings on software engineering, system design, and the connections worth making between disciplines.";
---

<BaseLayout title={title} description={description}>
  <h1 class="sr-only">Writings</h1>

  <!-- Category toggle -->
  <div
    class="category-toggle flex gap-0 mb-8"
    role="group"
    aria-label="Filter by category"
  >
    <button class="cat-btn active" data-cat="all" aria-pressed="true"
      >All</button
    >
    <button class="cat-btn" data-cat="posts" aria-pressed="false"
      >Posts</button
    >
    <button class="cat-btn" data-cat="essays" aria-pressed="false"
      >Essays</button
    >
  </div>

  <!-- Tag filter pills -->
  <div
    class="tags-bar flex flex-wrap gap-2 mb-8"
    role="group"
    aria-label="Filter by tag"
  >
    <button class="tag-pill active" data-tag="all" aria-pressed="true"
      >All</button
    >
    {
      allTags.map((tag) => (
        <button
          class="tag-pill"
          data-tag={tag}
          aria-pressed="false"
          data-count-all={tagCountsByCategory[tag].all}
          data-count-posts={tagCountsByCategory[tag].posts}
          data-count-essays={tagCountsByCategory[tag].essays}
        >
          {tag.replace(/-/g, " ")}
          <sup class="tag-count">{tagCountsByCategory[tag].all}</sup>
        </button>
      ))
    }
  </div>

  <!-- Search -->
  <section class="search-bar mb-8">
    <label for="search-input" class="sr-only">Search writings</label>
    <input
      type="text"
      id="search-input"
      placeholder="Search writings..."
      autocomplete="off"
      spellcheck="false"
    />
  </section>

  <!-- Result count -->
  <p class="result-count mb-4" aria-live="polite"></p>

  <!-- Writings list -->
  <section class="writings-section">
    {
      allWritings.map((w) => (
        <div
          class="list-row flex items-baseline gap-x-8"
          data-kind={`${w.kind}s`}
          data-tags={JSON.stringify(w.entry.data.tags || [])}
          data-title={w.entry.data.title}
        >
          <span class="kind-label" data-kind-label>{w.kind}</span>
          <a href={getEntryLink(w)} class="flex-1 truncate">
            {w.entry.data.title}
          </a>
          <time class="date-mono" datetime={isoDate(w.entry.data.date)}>
            {formatedYMD(w.entry.data.date)}
          </time>
        </div>
      ))
    }
  </section>
</BaseLayout>

<script>
  import "../scripts/list-filter";
</script>

<style>
  .writings-section {
    contain: layout;
  }

  .kind-label {
    width: 3rem;
  }
</style>
