---
import BaseLayout from "@layouts/base-layout.astro";
import SiteHeader from "@components/site-header.astro";
import { getAllPosts } from "@utils/all-posts";
import { getAllEssays } from "@utils/all-essays";
import { formatedYMD, isoDate } from "@utils/date-helper";
import { getPostLink } from "@utils/post-link";
import { createRequire } from "node:module";
const require = createRequire(import.meta.url);
const { active } = require("../../palettes.config.cjs");

const allPosts = await getAllPosts();
const allEssays = await getAllEssays();

const allTags = [
  ...new Set(
    [
      ...allPosts.flatMap((p) => p.data.tags),
      ...allEssays.flatMap((e) => e.data.tags),
    ].filter(Boolean),
  ),
] as string[];

const tagCountsByCategory = allTags.reduce(
  (acc, tag) => {
    const posts = allPosts.filter((p) => p.data.tags?.includes(tag)).length;
    const essays = allEssays.filter((e) => e.data.tags?.includes(tag)).length;
    acc[tag] = { all: posts + essays, posts, essays };
    return acc;
  },
  {} as Record<string, { all: number; posts: number; essays: number }>,
);

const title = "Writings";
const description = "Writings - Programs Fall Apart";
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <SiteHeader />

    <!-- Category toggle -->
    <div
      class="category-toggle flex justify-center gap-0 my-8"
      role="group"
      aria-label="Filter by category"
    >
      <button class="cat-btn active" data-cat="all" aria-pressed="true"
        >All</button
      >
      <button class="cat-btn" data-cat="posts" aria-pressed="false"
        >Posts</button
      >
      <button class="cat-btn" data-cat="essays" aria-pressed="false"
        >Essays</button
      >
    </div>

    <!-- Tag filter pills -->
    <div
      class="tags-bar flex flex-wrap gap-2 mb-8"
      role="group"
      aria-label="Filter by tag"
    >
      <button class="tag-pill active" data-tag="all" aria-pressed="true"
        >All</button
      >
      {
        allTags.map((tag) => (
          <button
            class="tag-pill"
            data-tag={tag}
            aria-pressed="false"
            data-count-all={tagCountsByCategory[tag].all}
            data-count-posts={tagCountsByCategory[tag].posts}
            data-count-essays={tagCountsByCategory[tag].essays}
          >
            {tag.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())}
            <sup class="tag-count">{tagCountsByCategory[tag].all}</sup>
          </button>
        ))
      }
    </div>

    <!-- Search -->
    <section class="search-bar mb-8">
      <label for="search-input" class="sr-only">Search writings</label>
      <input
        type="text"
        id="search-input"
        placeholder="Search writings..."
        autocomplete="off"
        spellcheck="false"
      />
    </section>

    <!-- Result count -->
    <p class="result-count mb-4" aria-live="polite"></p>

    <!-- Writings list -->
    <section
      class="writings-section"
      data-accent={active.accent}
      data-primary-dark={active["primary-dark"]}
    >
      {
        allPosts.map((post) => (
          <div
            class="writing-row flex items-baseline gap-x-8"
            data-kind="posts"
            data-tags={JSON.stringify(post.data.tags || [])}
            data-title={post.data.title}
          >
            <span class="kind-label">post</span>
            <a href={getPostLink(post)} class="flex-1 truncate">
              {post.data.title}
            </a>
            <time class="date-mono" datetime={isoDate(post.data.date)}>
              {formatedYMD(post.data.date)}
            </time>
          </div>
        ))
      }
      {
        allEssays.map((essay) => (
          <div
            class="writing-row flex items-baseline gap-x-8"
            data-kind="essays"
            data-tags={JSON.stringify(essay.data.tags || [])}
            data-title={essay.data.title}
          >
            <span class="kind-label">essay</span>
            <a href={`/essays/${essay.data.abbrlink}`} class="flex-1 truncate">
              {essay.data.title}
            </a>
          </div>
        ))
      }
    </section>
  </main>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const catBtns = document.querySelectorAll<HTMLButtonElement>(".cat-btn");
    const writingsSection =
      document.querySelector<HTMLElement>(".writings-section")!;
    const rows = document.querySelectorAll<HTMLElement>(
      ".writings-section .writing-row",
    );
    const searchInput = document.getElementById(
      "search-input",
    ) as HTMLInputElement;
    const accentColor = writingsSection.dataset.accent!;
    const primaryDark = writingsSection.dataset.primaryDark!;
    const resultCount = document.querySelector<HTMLElement>(".result-count")!;

    const allTagPill = document.querySelector<HTMLButtonElement>(
      '.tag-pill[data-tag="all"]',
    );
    const filterTagPills = document.querySelectorAll<HTMLButtonElement>(
      '.tag-pill:not([data-tag="all"])',
    );

    // Pre-parse tags once instead of on every filter
    const rowData = Array.from(rows).map((row) => ({
      el: row,
      kind: row.dataset.kind!,
      tags: JSON.parse(row.dataset.tags || "[]") as string[],
      title: row.dataset.title || "",
      link: row.querySelector("a")!,
    }));

    let activeCat = "all";
    let searchQuery = "";
    const activeTags = new Set<string>();

    function highlightText(text: string, query: string): string {
      if (!query) return text;
      const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      const re = new RegExp(`(${escaped})`, "gi");
      return text.replace(re, `<mark class="search-highlight">$1</mark>`);
    }

    function updateTagCounts() {
      filterTagPills.forEach((pill) => {
        const count =
          pill.dataset[
            `count${activeCat.charAt(0).toUpperCase() + activeCat.slice(1)}`
          ] || "0";
        const sup = pill.querySelector(".tag-count");
        if (sup) sup.textContent = count;
      });
    }

    function updateVisibility() {
      const showAllTags = activeTags.size === 0;
      allTagPill?.classList.toggle("active", showAllTags);
      allTagPill?.setAttribute("aria-pressed", String(showAllTags));
      filterTagPills.forEach((p) => {
        const isActive = activeTags.has(p.dataset.tag!);
        p.classList.toggle("active", isActive);
        p.setAttribute("aria-pressed", String(isActive));
      });

      let visible = 0;
      const query = searchQuery.toLowerCase();
      rowData.forEach(({ el, kind, tags, title, link }) => {
        const catMatch = activeCat === "all" || kind === activeCat;
        const tagMatch = showAllTags || tags.some((t) => activeTags.has(t));
        const searchMatch = !searchQuery || title.toLowerCase().includes(query);

        const show = catMatch && tagMatch && searchMatch;
        el.style.display = show ? "" : "none";
        if (show) visible++;
        link.innerHTML =
          searchQuery && searchMatch
            ? highlightText(title, searchQuery)
            : title;
      });

      resultCount.textContent = `${visible} ${visible === 1 ? "result" : "results"}`;
    }

    let searchTimer: number;
    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => {
        searchQuery = searchInput.value.trim();
        updateVisibility();
      }, 150);
    });

    catBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeCat = btn.dataset.cat!;
        catBtns.forEach((b) => {
          const isActive = b === btn;
          b.classList.toggle("active", isActive);
          b.setAttribute("aria-pressed", String(isActive));
        });
        updateTagCounts();
        updateVisibility();
      });
    });

    allTagPill?.addEventListener("click", () => {
      activeTags.clear();
      updateVisibility();
    });

    filterTagPills.forEach((pill) => {
      pill.addEventListener("click", () => {
        const tag = pill.dataset.tag!;
        if (activeTags.has(tag)) {
          activeTags.delete(tag);
        } else {
          activeTags.add(tag);
        }
        updateVisibility();
      });
    });

    updateVisibility();
  });
</script>

<style>
  .cat-btn {
    font-family: "JetBrains Mono";
    font-size: 0.65rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 0.35rem 1rem;
    border: 1px solid theme("colors.muted");
    background: transparent;
    color: theme("colors.muted");
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .cat-btn:first-child {
    border-radius: 4px 0 0 4px;
  }

  .cat-btn:last-child {
    border-radius: 0 4px 4px 0;
  }

  .cat-btn + .cat-btn {
    border-left: none;
  }

  .cat-btn:hover,
  .cat-btn.active {
    color: theme("colors.primary");
    border-color: theme("colors.primary");
  }

  .cat-btn.active + .cat-btn {
    border-left-color: theme("colors.primary");
  }

  .tag-pill {
    font-family: "JetBrains Mono";
    font-size: 0.6rem;
    letter-spacing: 1px;
    padding: 0.2rem 0.6rem;
    border: 1px solid theme("colors.muted");
    border-radius: 999px;
    background: transparent;
    color: theme("colors.muted");
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .tag-pill:hover,
  .tag-pill.active {
    color: theme("colors.primary");
    border-color: theme("colors.primary");
  }

  .tag-count {
    font-size: 0.55rem;
    margin-left: 0.2rem;
    opacity: 0.7;
  }

  .writing-row {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .writing-row a {
    text-decoration: none;
  }

  #search-input {
    width: 100%;
    font-family: "JetBrains Mono";
    font-size: 0.7rem;
    letter-spacing: 1px;
    padding: 0.4rem 0.8rem;
    border: 1px solid theme("colors.muted");
    border-radius: 4px;
    background: transparent;
    color: inherit;
    transition: border-color 0.15s ease;
  }

  #search-input::placeholder {
    color: theme("colors.muted");
    opacity: 0.6;
  }

  #search-input:focus {
    border-color: theme("colors.primary");
    outline: 2px solid theme("colors.primary");
    outline-offset: 2px;
  }

  .result-count {
    font-family: "JetBrains Mono";
    font-size: 0.6rem;
    letter-spacing: 1px;
    color: theme("colors.muted");
  }

  .writings-section {
    contain: layout;
  }

  .kind-label {
    font-family: "JetBrains Mono";
    font-size: 0.55rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: theme("colors.muted");
    white-space: nowrap;
    width: 3rem;
    flex-shrink: 0;
  }

  .writing-row .date-mono {
    font-size: 0.55rem;
  }

  :global(.search-highlight) {
    background: theme("colors.accent");
    color: theme("colors.primary-dark");
    border-radius: 2px;
    padding: 0 2px;
  }
</style>
