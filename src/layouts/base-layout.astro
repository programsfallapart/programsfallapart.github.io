---
import BaseHead from '@components/html-head.astro'
import SidebarNav from '@components/sidebar-nav.astro'
import ScrollButton from '@components/scroll-button.astro'
import SiteFooter from '@components/site-footer.astro'

const { title, description, mainClass } = Astro.props.frontmatter || Astro.props
const isAbout = Astro.url.pathname.replace(/\/+$/, '') === '/about'
---

<html lang="en">
  <BaseHead title={title} description={description} />
  <body class="bg-primary-white text-primary-dark dark:bg-primary-dark dark:text-[#e4e4e7]">
    <a href="#main-content" class="skip-link" data-skip-link>Skip to content</a>
    <div class="site-layout">
      <SidebarNav />
      <main id="main-content" tabindex="-1" class:list={[mainClass]}>
        <slot />
      </main>
    </div>
    <SiteFooter isAbout={isAbout} />
    <ScrollButton />
    <script>
      document.querySelector('[data-skip-link]')?.addEventListener('click', (e) => {
        e.preventDefault()
        const main = document.getElementById('main-content')
        if (main) {
          main.focus()
          main.scrollIntoView()
        }
      })
    </script>
  </body>
</html>
